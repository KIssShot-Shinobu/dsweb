{
  "name": "dsweb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "db:preflight": "node scripts/prisma-preflight.js",
    "dev:setup": "npx prisma generate && npx prisma db push",
    "dev:ready": "npm run dev:setup && npm run dev",
    "build": "next build --webpack",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "migrate:local": "tsx scripts/migrate-sqlite-to-mysql.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/**/*.test.ts",
    "seed:admin": "node scripts/seed-admin.js",
    "seed:dev": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@mantine/core": "^8.3.17",
    "@mantine/dates": "^8.3.17",
    "@mantine/hooks": "^8.3.17",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.33.0",
    "jose": "^6.1.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.563.0",
    "mariadb": "^3.5.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "pg": "^8.20.0",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-svg-pan-zoom": "^3.13.1",
    "react-tournament-brackets": "^1.0.41",
    "styled-components": "^6.3.11",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
