// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ─── ENUMS FOR TYPE SAFETY ───────────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  BANNED
}

enum UserRole {
  USER
  MEMBER
  OFFICER
  ADMIN
  FOUNDER
}

enum GuildStatus {
  SOLO_PLAYER
  LEFT_GUILD
  NEW_PLAYER
}

enum GameType {
  DUEL_LINKS
  MASTER_DUEL
}

enum TournamentFormat {
  BO1
  BO3
  BO5
}

enum TournamentStatus {
  OPEN
  ONGOING
  COMPLETED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ─── Existing Models (unchanged) ─────────────────────────────────────────────

model Member {
  id           String     @id @default(cuid())
  name         String
  gameId       String     @unique @db.VarChar(191)
  rank         String?
  role         String     @default("MEMBER")
  joinedAt     DateTime   @default(now())
  transactions Treasury[]
}

model Tournament {
  id          String           @id @default(cuid())
  title       String
  description String?
  format      TournamentFormat @default(BO3)
  gameType    GameType         @default(DUEL_LINKS)
  status      TournamentStatus @default(OPEN)
  entryFee    Int              @default(0)
  prizePool   Int              @default(0)
  startDate   DateTime
  image       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  participants TournamentParticipant[]
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId       String     // Snapshot of IGN or Game ID used at registration
  joinedAt     DateTime   @default(now())

  @@unique([tournamentId, userId])
}

model Treasury {
  id          String   @id @default(cuid())
  amount      Int
  description String
  createdAt   DateTime @default(now())
  memberId    String?
  member      Member?  @relation(fields: [memberId], references: [id])
}

// ─── New: Auth / Registration System ─────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  fullName      String
  email         String     @unique @db.VarChar(191)
  password      String
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  lastActiveAt  DateTime   @default(now()) @updatedAt
  privacySettings Json?
  bio           String?    @db.VarChar(500)
  timezone      String?    @default("Asia/Jakarta") @db.VarChar(50)
  language      String?    @default("id") @db.VarChar(10)
  discordId     String?    @unique @db.VarChar(191)
  instagramHandle String?  @db.VarChar(191)
  twitterHandle String?    @db.VarChar(191)
  dateOfBirth   DateTime?
  gender        Gender?
  phoneWhatsapp String?    @unique @db.VarChar(191)
  city          String?
  avatarUrl     String?
  status        UserStatus @default(PENDING)
  role          UserRole   @default(USER)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  gameProfiles    GameProfile[]
  registrationLog RegistrationLog?
  auditLogs       AuditLog[]
  tournaments     TournamentParticipant[]
  emailVerificationToken EmailVerificationToken?
  passwordResetToken PasswordResetToken?
  sessions        Session[]
  badges          UserBadge[]
  reputationLogs  ReputationLog[]
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  iconUrl     String?
  criteria    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())
  context   String?

  @@unique([userId, badgeId])
  @@index([userId])
}

model ReputationLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  reason      String
  sourceType  String?
  sourceId    String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(191)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(191)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @db.VarChar(191)
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model GameProfile {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType      GameType
  gameId        String   @unique @db.VarChar(191)
  ign           String
  screenshotUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RegistrationLog {
  id          String      @id @default(cuid())
  userId      String      @unique @db.VarChar(191)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceInfo  String?
  prevGuild   String?
  guildStatus GuildStatus
  socialMedia String?
  agreement   Boolean     @default(true)
  createdAt   DateTime    @default(now())
}

// ─── AUDIT LOG SYSTEM (MERGED AdminLog + AuditLog) ───────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  userId         String   @default("0")
  user           User?    @relation(fields: [userId], references: [id])
  action         String
  targetId       String?
  targetType     String?
  ipAddress      String
  userAgent      String?
  requestPath    String?
  requestMethod  String?
  responseStatus Int?
  reason         String?
  details        String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@index([responseStatus])
}
