// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Existing Models (unchanged) ─────────────────────────────────────────────

model Member {
  id        String   @id @default(cuid())
  name      String
  gameId    String   @unique
  rank      String?
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  transactions Treasury[]
}

model Tournament {
  id          String   @id @default(cuid())
  title       String
  gameType    String
  status      String   @default("UPCOMING")
  startDate   DateTime
  prizePool   Int      @default(0)
  description String?
  image       String?
}

model Treasury {
  id          String   @id @default(cuid())
  amount      Int
  description String
  createdAt   DateTime @default(now())
  memberId    String?
  member      Member?  @relation(fields: [memberId], references: [id])
}

// ─── New: Auth / Registration System ─────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  password        String
  phoneWhatsapp   String?   @unique
  city            String?
  avatarUrl       String?
  status          String    @default("PENDING")  // PENDING, ACTIVE, REJECTED, BANNED
  role            String    @default("USER")      // USER, MEMBER, OFFICER, ADMIN, FOUNDER
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  gameProfiles    GameProfile[]
  registrationLog RegistrationLog?
  adminLogsGiven  AdminLog[]       @relation("AdminLogs")
  adminLogsTarget AdminLog[]       @relation("TargetLogs")
}

model GameProfile {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType      String    // DUEL_LINKS, MASTER_DUEL
  gameId        String    @unique
  ign           String    // Must start with [DS]
  screenshotUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RegistrationLog {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceInfo   String?   // How they found the guild
  prevGuild    String?   // Previous guild name
  guildStatus  String    // SOLO_PLAYER, LEFT_GUILD, NEW_PLAYER
  socialMedia  String?   // JSON array stored as string
  agreement    Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminLogs", fields: [adminId], references: [id])
  targetId  String?
  target    User?    @relation("TargetLogs", fields: [targetId], references: [id])
  action    String   // APPROVE, REJECT, BAN, UNBAN, ROLE_CHANGE, etc.
  reason    String?
  details   String?  // JSON as string
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @default("0") // Mengacu pada User.id (String). Gunakan "0" untuk sistem/tamu
  action      String   // LOGIN_SUCCESS, MEMBER_APPROVED, dll
  targetId    String?  // ID target aksi
  targetType  String?  // Tipe target: USER, GAME_PROFILE, dll
  ipAddress   String
  userAgent   String?  // Optional, sometimes user agent can be missing or very long
  details     String?  // JSON as string
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
}