// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ENUMS FOR TYPE SAFETY
enum UserStatus {
  ACTIVE
  BANNED
}

enum UserRole {
  USER
  MEMBER
  OFFICER
  ADMIN
  FOUNDER
}

enum TournamentFormat {
  BO1
  BO3
  BO5
}

enum TournamentStatus {
  OPEN
  ONGOING
  COMPLETED
  CANCELLED
}

enum TournamentStructure {
  SINGLE_ELIM
  DOUBLE_ELIM
  SWISS
}

enum TournamentForfeitMode {
  CHECKIN_ONLY
  SCHEDULE_NO_SHOW
}

enum TournamentMode {
  INDIVIDUAL
  TEAM_BOARD
  TEAM_KOTH
}

enum RoundType {
  MAIN
  UPPER
  LOWER
  GRAND_FINAL
  SWISS
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PendingUploadPurpose {
  REGISTER_SCREENSHOT
}

enum PendingUploadStatus {
  TEMP
  CLAIMED
  EXPIRED
}

enum TeamRole {
  CAPTAIN
  VICE_CAPTAIN
  PLAYER
  COACH
  MANAGER
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TournamentStaffRole {
  REFEREE
  STAFF
}

enum TeamJoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TeamCreationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TEAM_INVITE
  TEAM_JOIN_REQUEST
  TEAM_ROLE_CHANGED
  TEAM_MEMBER_REMOVED
  TOURNAMENT_INVITE
  MATCH_SCHEDULED
  MATCH_RESULT
  SYSTEM_ALERT
}

enum MatchStatus {
  PENDING
  READY
  ONGOING
  RESULT_SUBMITTED
  CONFIRMED
  DISPUTED
  COMPLETED
}

enum MatchPlayerSide {
  A
  B
}

enum MatchResultSource {
  PLAYER
  ADMIN
  SYSTEM
}

enum MatchDisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum TournamentParticipantStatus {
  REGISTERED
  CHECKED_IN
  DISQUALIFIED
  PLAYING
  WAITLIST
}

enum TournamentPaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(191)
  slug        String   @unique @db.VarChar(191)
  description String?  @db.VarChar(500)
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships           TeamMember[]
  invites               TeamInvite[]
  joinRequests          TeamJoinRequest[]
  tournamentParticipants TournamentParticipant[]
}

model Tournament {
  id          String              @id @default(cuid())
  title       String
  description String?           @db.VarChar(1000)
  format      TournamentFormat    @default(BO3)
  gameId      String
  game        Game                @relation(fields: [gameId], references: [id], onDelete: Restrict)
  status      TournamentStatus    @default(OPEN)
  structure   TournamentStructure @default(SINGLE_ELIM)
  mode        TournamentMode      @default(INDIVIDUAL)
  isTeamTournament Boolean        @default(false)
  checkinRequired Boolean         @default(false)
  checkInOpen Boolean             @default(false)
  checkInAt   DateTime?
  forfeitEnabled Boolean          @default(false)
  forfeitGraceMinutes Int         @default(15)
  forfeitMode TournamentForfeitMode @default(CHECKIN_ONLY)
  minPlayers Int?
  maxPlayers Int?
  bracketSize Int?
  registrationOpen DateTime?
  registrationClose DateTime?
  entryFee    Int                 @default(0)
  prizePool   Int                 @default(0)
  startAt     DateTime
  image       String?
  createdById String
  createdBy   User                @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  participants  TournamentParticipant[]
  rounds        TournamentRound[]
  matches       Match[]
  bracketNodes  BracketNode[]
  announcements TournamentAnnouncement[]
  staffAssignments TournamentStaff[]

  @@index([createdById])
  @@index([gameId])
  @@index([status, startAt])
  @@index([structure, startAt])
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  guestName    String?    @db.VarChar(191)
  gameId       String // Snapshot of IGN or Game ID used at registration
  status       TournamentParticipantStatus @default(REGISTERED)
  paymentStatus TournamentPaymentStatus @default(VERIFIED)
  paymentProofUrl String? @db.VarChar(191)
  paymentVerifiedAt DateTime?
  checkedInAt  DateTime?
  seed         Int?
  seededAt     DateTime?
  joinedAt     DateTime   @default(now())

  matchesAsPlayerA Match[]       @relation("MatchPlayerA")
  matchesAsPlayerB Match[]       @relation("MatchPlayerB")
  matchesWon       Match[]       @relation("MatchWinner")
  matchPlayers     MatchPlayer[]
  matchResultsWon  MatchResult[] @relation("MatchResultWinner")

  @@unique([tournamentId, userId])
  @@unique([tournamentId, teamId])
  @@unique([tournamentId, guestName])
  @@index([tournamentId])
  @@index([userId])
  @@index([tournamentId, seed])
  @@index([tournamentId, checkedInAt])
}

model TournamentAnnouncement {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  title        String     @db.VarChar(191)
  content      String
  pinned       Boolean    @default(false)
  createdById  String
  createdBy    User       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tournamentId, createdAt])
  @@index([tournamentId, pinned])
  @@index([createdById])
}

model Treasury {
  id          String   @id @default(cuid())
  amount      Int
  currency    String   @default("IDR") @db.VarChar(10)
  description String
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

//  New: Auth / Registration System 

model User {
  id                String     @id @default(cuid())
  fullName          String     @db.VarChar(191)
  username          String     @unique @db.VarChar(191)
  email             String     @unique @db.VarChar(191)
  password          String
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  twoFactorEnabled  Boolean    @default(false)
  twoFactorSecret   String?    @db.VarChar(255)
  lastActiveAt      DateTime   @default(now()) @updatedAt
  privacySettings   Json?
  bio               String?    @db.VarChar(500)
  timezone          String?    @default("Asia/Jakarta") @db.VarChar(50)
  language          String?    @default("id") @db.VarChar(10)
  googleId          String?    @unique @db.VarChar(191)
  discordId         String?    @unique @db.VarChar(191)
  instagramHandle   String?    @db.VarChar(191)
  twitterHandle     String?    @db.VarChar(191)
  dateOfBirth       DateTime?
  gender            Gender?
  phoneWhatsapp     String?    @db.VarChar(255)
  phoneWhatsappHash String?    @unique @db.VarChar(64)
  // SECURITY NOTE:
  // accountNumber should be encrypted at application layer.
  // Only store encrypted value or masked value if possible.
  accountNumber     String?    @db.VarChar(255)
  accountNumberHash String?    @db.VarChar(64)
  provinceCode      String?    @db.VarChar(16)
  provinceName      String?    @db.VarChar(191)
  cityCode          String?    @db.VarChar(16)
  city              String?    @db.VarChar(191)
  avatarUrl         String?
  status            UserStatus @default(ACTIVE)
  role              UserRole   @default(USER)
  authVersion       Int        @default(0)
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  teamMemberships              TeamMember[]
  receivedTeamInvites          TeamInvite[]             @relation("TeamInviteTargetUser")
  sentTeamInvites              TeamInvite[]             @relation("TeamInviteSender")
  teamJoinRequests             TeamJoinRequest[]
  teamCreationRequests         TeamCreationRequest[]    @relation("TeamCreationRequester")
  reviewedTeamCreationRequests TeamCreationRequest[]    @relation("TeamCreationReviewer")
  notifications                Notification[]
  notificationPreference       NotificationPreference?
  playerGameAccounts           PlayerGameAccount[]
  tournamentAnnouncements      TournamentAnnouncement[]
  registrationLog              RegistrationLog?
  auditLogs                    AuditLog[]
  tournaments                  TournamentParticipant[]
  createdTournaments           Tournament[]             @relation("TournamentCreator")
  tournamentStaffAssignments   TournamentStaff[]
  matchReports                 MatchReport[]
  matchResultsConfirmed        MatchResult[]            @relation("MatchResultConfirmedBy")
  matchDisputesRaised          MatchDispute[]           @relation("MatchDisputeRaisedBy")
  matchDisputesResolved        MatchDispute[]           @relation("MatchDisputeResolvedBy")
  matchMessages                MatchMessage[]
  emailVerificationToken       EmailVerificationToken?
  passwordResetToken           PasswordResetToken?
  badges                       UserBadge[]
  reputationLogs               ReputationLog[]
  treasuryEntries              Treasury[]
  claimedUploads               PendingUpload[]

  @@index([accountNumberHash])
  @@index([status])
  @@index([role])
  @@index([lastActiveAt])
  @@index([createdAt])
}

model TournamentStaff {
  id           String              @id @default(cuid())
  tournamentId String
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         TournamentStaffRole @default(REFEREE)
  createdAt    DateTime            @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId, role])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(191)
  message   String           @db.VarChar(500)
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     Boolean  @default(true)
  inApp     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String    @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole  @default(PLAYER)
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId, leftAt])
  @@index([userId, leftAt])
  @@index([teamId, role, leftAt])
}

model TeamInvite {
  id          String           @id @default(cuid())
  teamId      String
  userId      String
  invitedById String
  status      TeamInviteStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User @relation("TeamInviteTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId, status])
  @@index([userId, status])
}

model TeamJoinRequest {
  id        String                @id @default(cuid())
  teamId    String
  userId    String
  status    TeamJoinRequestStatus @default(PENDING)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId, status])
  @@index([userId, status])
}

model TeamCreationRequest {
  id              String                    @id @default(cuid())
  requesterId     String
  reviewerId      String?
  teamName        String                    @db.VarChar(191)
  description     String?                   @db.VarChar(500)
  logoUrl         String?
  status          TeamCreationRequestStatus @default(PENDING)
  rejectionReason String?                   @db.VarChar(500)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  reviewedAt      DateTime?

  requester User  @relation("TeamCreationRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer  User? @relation("TeamCreationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requesterId, status])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  iconUrl     String?
  criteria    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())
  context  String?

  @@unique([userId, badgeId])
  @@index([userId])
}

model ReputationLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points     Int
  reason     String
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(191)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(191)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Game {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(191)
  type      String?  @db.VarChar(50)
  isOnline  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments Tournament[]
  accounts    PlayerGameAccount[]
}

model PlayerGameAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gamePlayerId  String   @db.VarChar(191)
  ign           String
  screenshotUrl String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, gameId])
  @@unique([gameId, gamePlayerId])
  @@index([userId])
}

model RegistrationLog {
  id          String   @id @default(cuid())
  userId      String   @unique @db.VarChar(191)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceInfo  String?
  socialMedia String?
  agreement   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PendingUpload {
  id              String               @id @default(cuid())
  purpose         PendingUploadPurpose
  status          PendingUploadStatus  @default(TEMP)
  storageKey      String               @unique @db.VarChar(191)
  originalName    String               @db.VarChar(191)
  mimeType        String               @db.VarChar(100)
  size            Int
  ipAddress       String               @db.VarChar(64)
  claimedByUserId String?
  claimedByUser   User?                @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime?
  expiresAt       DateTime
  createdAt       DateTime             @default(now())

  @@index([ipAddress, createdAt])
  @@index([status, expiresAt])
  @@index([claimedByUserId])
}

//  AUDIT LOG SYSTEM (MERGED AdminLog + AuditLog) 

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  action         String
  targetId       String?
  targetType     String?
  ipAddress      String
  userAgent      String?
  requestPath    String?
  requestMethod  String?
  responseStatus Int?
  reason         String?
  details        String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@index([responseStatus])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model TournamentRound {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  roundNumber Int
  type        RoundType @default(MAIN)
  name        String?   @db.VarChar(191)
  isActive    Boolean   @default(false)
  startedAt   DateTime?
  completedAt DateTime?

  matches Match[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bracketNodes BracketNode[]

  @@unique([tournamentId, roundNumber, type])
  @@index([tournamentId, type, roundNumber])
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  roundId String
  round   TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  bracketIndex Int
  status       MatchStatus @default(PENDING)

  playerAId String?
  playerBId String?
  playerA   TournamentParticipant? @relation("MatchPlayerA", fields: [playerAId], references: [id], onDelete: SetNull)
  playerB   TournamentParticipant? @relation("MatchPlayerB", fields: [playerBId], references: [id], onDelete: SetNull)

  winnerId String?
  winner   TournamentParticipant? @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  scoreA Int? @default(0)
  scoreB Int? @default(0)

  nextMatchId        String?
  nextMatchSide      MatchPlayerSide?
  loserNextMatchId   String?
  loserNextMatchSide MatchPlayerSide?

  scheduledAt  DateTime?
  reminderSentAt DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  matchVersion Int       @default(1)

  reports  MatchReport[]
  disputes MatchDispute[]
  players  MatchPlayer[]
  result   MatchResult?
  messages MatchMessage[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bracketNode BracketNode?

  @@index([tournamentId, roundId])
  @@index([roundId, bracketIndex])
  @@index([playerAId, status])
  @@index([playerBId, status])
  @@index([status])
}

model MatchPlayer {
  id            String                @id @default(cuid())
  matchId       String
  match         Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participantId String
  participant   TournamentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  side          MatchPlayerSide

  @@unique([matchId, participantId])
  @@unique([matchId, side])
  @@index([participantId])
}

model MatchReport {
  id           String            @id @default(cuid())
  matchId      String
  match        Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reportedById String
  reportedBy   User              @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  scoreA       Int
  scoreB       Int
  winnerId     String
  resultSource MatchResultSource @default(PLAYER)
  evidenceUrls Json?
  createdAt    DateTime          @default(now())

  @@unique([matchId, reportedById])
  @@index([matchId])
  @@index([reportedById])
}

model MatchResult {
  id            String                @id @default(cuid())
  matchId       String                @unique
  match         Match                 @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerId      String
  winner        TournamentParticipant @relation("MatchResultWinner", fields: [winnerId], references: [id], onDelete: Cascade)
  scoreA        Int
  scoreB        Int
  confirmedById String?
  confirmedBy   User?                 @relation("MatchResultConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  source        MatchResultSource     @default(PLAYER)
  createdAt     DateTime              @default(now())

  @@index([winnerId])
}

model MatchDispute {
  id           String             @id @default(cuid())
  matchId      String
  match        Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  raisedById   String
  raisedBy     User               @relation("MatchDisputeRaisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  status       MatchDisputeStatus @default(OPEN)
  reason       String?            @db.VarChar(500)
  evidenceUrls Json?
  resolvedById String?
  resolvedBy   User?              @relation("MatchDisputeResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNote String?          @db.VarChar(500)
  resolutionEvidenceUrls Json?
  createdAt    DateTime           @default(now())
  resolvedAt   DateTime?

  @@index([matchId, status])
  @@index([raisedById])
}

model MatchMessage {
  id             String   @id @default(cuid())
  matchId        String
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String   @db.VarChar(1000)
  attachmentUrls Json?
  createdAt      DateTime @default(now())
  editedAt       DateTime?

  @@index([matchId, createdAt])
  @@index([senderId])
}

model BracketNode {
  id           String          @id @default(cuid())
  tournamentId String
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchId      String          @unique
  match        Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  roundId      String
  round        TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  slotIndex    Int
  depth        Int
  nextNodeId   String?
  nextNode     BracketNode?    @relation("BracketNodeNext", fields: [nextNodeId], references: [id], onDelete: SetNull)
  prevNodes    BracketNode[]   @relation("BracketNodeNext")
  createdAt    DateTime        @default(now())

  @@index([tournamentId, depth])
  @@index([roundId, slotIndex])
}
